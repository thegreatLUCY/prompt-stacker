{
  "manifest_version": 3,
  "name": "Prompt Stacker — ChatGPT, Claude, Gemini & more",
  "version": "1.4.0",
  "description": "Queue prompts and auto-send the next when the AI finishes replying. Works on ChatGPT, Claude, Gemini, Google AI & DeepSeek.",
  "permissions": ["storage"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.google.com/search*",
        "https://chat.deepseek.com/*"
      ],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon16.png", "icon48.png", "icon128.png"],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.google.com/*",
        "https://chat.deepseek.com/*"
      ]
    }
  ]
}
